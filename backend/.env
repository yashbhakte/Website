# ═════════════════════════════════════════════════════════════════════
# FABRICGUARD BACKEND CONFIGURATION
# ═════════════════════════════════════════════════════════════════════

# To use MongoDB Atlas professionally, change this URI to your Atlas Connection String:
# Example: mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017

# Database Name inside MongoDB
DB_NAME=fabricguard

# Security configuration (for JWT authentication tokens)
SECRET_KEY=neuai-secret-key-for-fabricguard
