# Enter your credentials when you connect to the Cloudflare company portal.

# 1. Cloudflare Account ID (found on your Cloudflare Dashboard right-side sidebar)
CLOUDFLARE_ACCOUNT_ID=43e6d2babab321e5313c7c246158610b

# 2. R2 API Token Access Key Credentials (generated via R2 -> Manage R2 API Tokens)
CLOUDFLARE_R2_ACCESS_KEY_ID=429f01142ed47ef8432af5e10e18eb3a
CLOUDFLARE_R2_SECRET_ACCESS_KEY=c86cb597efabe37d26d33bf8d7f3cdaddec33f69c48db0ed5f81084a66ece82a

# 3. R2 Bucket Configuration
CLOUDFLARE_R2_BUCKET_NAME=neuaitechnologies

