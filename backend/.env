# ═════════════════════════════════════════════════════════════════════
# FABRICGUARD BACKEND CONFIGURATION
# ═════════════════════════════════════════════════════════════════════

# To use MongoDB Atlas professionally, change this URI to your Atlas Connection String:
# Example: mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017

# Database Name inside MongoDB
DB_NAME=fabricguard

# Security configuration (for JWT authentication tokens)
SECRET_KEY=neuai-secret-key-for-fabricguard

# ═════════════════════════════════════════════════════════════════════
# CLOUDFLARE R2 CLOUD STORAGE CONFIGURATION
# ═════════════════════════════════════════════════════════════════════
# Leave these empty to fall back to local image serving. 
# Enter your credentials when you connect to the Cloudflare company portal.

# 1. Cloudflare Account ID (found on your Cloudflare Dashboard right-side sidebar)
CLOUDFLARE_ACCOUNT_ID=43e6d2babab321e5313c7c246158610b

# 2. R2 API Token Access Key Credentials (generated via R2 -> Manage R2 API Tokens)
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=

# 3. R2 Bucket Configuration
CLOUDFLARE_R2_BUCKET_NAME=

# 4. Public Bucket Access URL (e.g., https://pub-xxxxxx.r2.dev or custom subdomain)
CLOUDFLARE_R2_PUBLIC_URL=

